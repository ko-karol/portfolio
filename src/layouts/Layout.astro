---
import '../styles/papercraft.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Software developer specialising in fast, thoughtful products. Available for freelance and full-time opportunities." />
  <meta name="author" content="Karol" />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Lora:ital@0;1&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ─── THREE.JS BACKGROUND CANVAS ──────────────────────── -->
  <canvas id="bg-canvas" aria-hidden="true"></canvas>

  <!-- ─── SKIP LINK ────────────────────────────────────────── -->
  <a href="#main" class="skip-link">Skip to content</a>

  <!-- ─── NAV ─────────────────────────────────────────────── -->
  <header class="site-header" role="banner">
    <nav class="nav" aria-label="Main navigation">
      <a href="/#hero" class="nav-logo" aria-label="Home">
        <span class="nav-logo-mark">K</span>
        <span class="nav-logo-dot"></span>
      </a>
      <ul class="nav-links" role="list">
        <li><a href="/#work"    class="nav-link">Work</a></li>
        <li><a href="/#process" class="nav-link">Process</a></li>
        <li><a href="/#about"   class="nav-link">About</a></li>
        <li><a href="/signal" class="nav-link">Signal</a></li>
        <li><a href="/#contact" class="nav-link btn-nav">Let's talk</a></li>
      </ul>
      <button class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </nav>
    <div class="mobile-menu" id="mobile-menu" hidden>
      <ul role="list">
        <li><a href="/#work"    class="mobile-link">Work</a></li>
        <li><a href="/#process" class="mobile-link">Process</a></li>
        <li><a href="/#about"   class="mobile-link">About</a></li>
        <li><a href="/signal" class="mobile-link">Signal</a></li>
        <li><a href="/#contact" class="mobile-link">Let's talk</a></li>
      </ul>
    </div>
  </header>

  <slot />

  <!-- ─── FOOTER ────────────────────────────────────────────── -->
  <footer class="site-footer" role="contentinfo">
    <div class="container footer-inner">
      <span class="footer-brand">Karol.</span>
      <span class="footer-copy">© {new Date().getFullYear()} — crafted with CSS 3D &amp; care</span>
      <a href="/#hero" class="footer-back" aria-label="Back to top">↑ Top</a>
    </div>
  </footer>

  <script src="../scripts/main.js"></script>
</body>
</html>
